<?xml version="1.0" encoding="utf-8"?>

<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"

    xmlns:app="http://schemas.android.com/apk/res-auto"

    xmlns:tools="http://schemas.android.com/tools"

    android:layout_width="match_parent"

    android:layout_height="match_parent"

    android:background="#101010"

    tools:context=".Activities.Splash.SplashActivity">

    <!-- 배경 Glow -->
    <View
        android:id="@+id/glowView"

        android:layout_width="260dp"
        android:layout_height="260dp"

        android:background="@drawable/bg_glow"

        app:layout_constraintTop_toTopOf="parent"

        app:layout_constraintBottom_toBottomOf="parent"

        app:layout_constraintStart_toStartOf="parent"

        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- 아이콘 -->
    <TextView
        android:id="@+id/logoText"

        android:layout_width="wrap_content"
        android:layout_height="wrap_content"

        android:text="⏳"

        android:textSize="72sp"

        android:textColor="#FFD700"

        app:layout_constraintTop_toTopOf="parent"

        app:layout_constraintStart_toStartOf="parent"

        app:layout_constraintEnd_toEndOf="parent"

        app:layout_constraintBottom_toTopOf="@id/titleText"

        android:layout_marginBottom="16dp"/>

    <!-- 제목 -->
    <TextView
        android:id="@+id/titleText"

        android:layout_width="wrap_content"
        android:layout_height="wrap_content"

        android:text="시간은 금이다"

        android:textColor="#FFFFFF"

        android:textStyle="bold"

        android:textSize="32sp"

        app:layout_constraintTop_toBottomOf="@id/logoText"

        app:layout_constraintStart_toStartOf="parent"

        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- 명언 -->
    <TextView
        android:id="@+id/quoteText"

        android:layout_width="0dp"
        android:layout_height="wrap_content"

        android:text="당신이 잠을 자는 동안 누군가는 꿈을 이룹니다."

        android:textColor="#CCCCCC"

        android:textSize="18sp"

        android:gravity="center"

        android:paddingHorizontal="32dp"

        android:layout_marginTop="48dp"

        app:layout_constraintTop_toBottomOf="@id/titleText"

        app:layout_constraintStart_toStartOf="parent"

        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Loading -->
    <TextView
        android:id="@+id/loadingText"

        android:layout_width="wrap_content"
        android:layout_height="wrap_content"

        android:text="Loading..."

        android:textColor="#FFD700"

        android:textSize="16sp"

        android:layout_marginTop="48dp"

        app:layout_constraintTop_toBottomOf="@id/quoteText"

        app:layout_constraintStart_toStartOf="parent"

        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Progress -->
    <ProgressBar
        android:id="@+id/progressBar"

        style="?android:attr/progressBarStyleHorizontal"

        android:layout_width="220dp"

        android:layout_height="8dp"

        android:progressTint="#FFD700"

        android:indeterminate="true"

        android:layout_marginTop="16dp"

        app:layout_constraintTop_toBottomOf="@id/loadingText"

        app:layout_constraintStart_toStartOf="parent"

        app:layout_constraintEnd_toEndOf="parent"/>
</androidx.constraintlayout.widget.ConstraintLayout>