<?xml version="1.0" encoding="utf-8"?>

<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"

    xmlns:app="http://schemas.android.com/apk/res-auto"

    android:layout_width="match_parent"

    android:layout_height="match_parent"

    android:background="#101010">

    <!-- 제목 -->
    <TextView
        android:id="@+id/titleTextView"

        android:layout_width="wrap_content"

        android:layout_height="wrap_content"

        android:text="TODO 제목"

        android:textColor="#FFFFFF"

        android:textStyle="bold"

        android:textSize="30sp"

        android:layout_marginTop="24dp"

        android:layout_marginStart="24dp"

        app:layout_constraintTop_toTopOf="parent"

        app:layout_constraintStart_toStartOf="parent"/>

    <!-- 현재 가치 -->
    <TextView
        android:id="@+id/currentValueText"

        android:layout_width="wrap_content"

        android:layout_height="wrap_content"

        android:text=""

        android:textColor="#FFD700"

        android:textStyle="bold"

        android:textSize="24sp"

        android:layout_marginTop="16dp"

        android:layout_marginStart="24dp"

        app:layout_constraintTop_toBottomOf="@id/titleTextView"

        app:layout_constraintStart_toStartOf="parent"/>

    <!-- 그래프 카드 -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/chartCard"

        android:layout_width="0dp"

        android:layout_height="320dp"

        android:layout_margin="24dp"

        app:cardCornerRadius="28dp"

        app:cardElevation="10dp"

        app:cardBackgroundColor="#1E1E1E"

        app:layout_constraintTop_toBottomOf="@id/currentValueText"

        app:layout_constraintStart_toStartOf="parent"

        app:layout_constraintEnd_toEndOf="parent">

        <com.github.mikephil.charting.charts.LineChart
            android:id="@+id/lineChart"

            android:layout_width="match_parent"

            android:layout_height="match_parent"

            android:padding="16dp"/>
    </com.google.android.material.card.MaterialCardView>

    <LinearLayout
        android:id="@+id/statLayout"

        android:layout_width="0dp"

        android:layout_height="wrap_content"

        android:orientation="vertical"

        android:layout_marginHorizontal="24dp"

        android:layout_marginTop="12dp"

        app:layout_constraintTop_toBottomOf="@id/chartCard"

        app:layout_constraintStart_toStartOf="parent"

        app:layout_constraintEnd_toEndOf="parent">

        <!-- 첫 줄 -->
        <LinearLayout
            android:layout_width="match_parent"

            android:layout_height="wrap_content"

            android:orientation="horizontal">

            <TextView
                android:id="@+id/minText"

                android:layout_width="0dp"

                android:layout_height="wrap_content"

                android:layout_weight="1"

                android:text="MIN : 0"

                android:textColor="#2196F3"

                android:textSize="18sp"

                android:textStyle="bold"/>

            <TextView
                android:id="@+id/maxText"

                android:layout_width="0dp"

                android:layout_height="wrap_content"

                android:layout_weight="1"

                android:gravity="end"

                android:text="MAX : 0"

                android:textColor="#F44336"

                android:textSize="18sp"

                android:textStyle="bold"/>
        </LinearLayout>

        <!-- 두번째 줄 -->
        <LinearLayout
            android:layout_width="match_parent"

            android:layout_height="wrap_content"

            android:orientation="horizontal"

            android:layout_marginTop="12dp">

            <TextView
                android:id="@+id/avgText"

                android:layout_width="0dp"

                android:layout_height="wrap_content"

                android:layout_weight="1"

                android:text="AVG : 0"

                android:textColor="#FFD700"

                android:textSize="18sp"

                android:textStyle="bold"/>

            <TextView
                android:id="@+id/medianText"

                android:layout_width="0dp"

                android:layout_height="wrap_content"

                android:layout_weight="1"

                android:gravity="end"

                android:text="MEDIAN : 0"

                android:textColor="#4CAF50"

                android:textSize="18sp"

                android:textStyle="bold"/>
        </LinearLayout>

        <!-- 선택 데이터 -->
        <TextView
            android:id="@+id/selectedPointText"

            android:layout_width="wrap_content"

            android:layout_height="wrap_content"

            android:text=""

            android:textColor="#FFD700"

            android:textSize="17sp"

            android:textStyle="bold"

            android:layout_marginTop="20dp"/>
    </LinearLayout>

    <!-- 수정 버튼 -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/editButton"

        android:layout_width="0dp"

        android:layout_height="wrap_content"

        android:text="TODO 수정하기"

        android:textStyle="bold"

        android:textSize="18sp"

        android:layout_marginHorizontal="24dp"

        android:layout_marginBottom="32dp"

        app:cornerRadius="20dp"

        app:backgroundTint="#FFD700"

        android:textColor="#000000"

        app:layout_constraintBottom_toBottomOf="parent"

        app:layout_constraintStart_toStartOf="parent"

        app:layout_constraintEnd_toEndOf="parent"/>
</androidx.constraintlayout.widget.ConstraintLayout>